# PostgreSQL (Railway)
# Use the Postgres plugin "Connection" / "Private URL" (postgresql://...:5432/...).
# P1013 "invalid port" on deploy = malformed URL: wrong variable, unescaped password (@ : /),
# quotes inside the value, or prisma+postgres:// (use plain postgresql:// on Railway).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Auth.js / NextAuth (generate: openssl rand -base64 32)
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Stripe (Phase 1 checkout)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Resend
RESEND_API_KEY=""

# OpenAI (optional, later)
OPENAI_API_KEY=""
# Optional seed (prisma db seed)
SEED_HYPER_ADMIN_EMAIL=
SEED_HYPER_ADMIN_PASSWORD=

