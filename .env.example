# PostgreSQL (Railway)
# Use the Postgres plugin "Connection" / "Private URL" (postgresql://...:5432/...).
# P1013 "invalid port" on deploy = malformed URL: wrong variable, unescaped password (@ : /),
# quotes inside the value, or prisma+postgres:// (use plain postgresql:// on Railway).
# Meta Pixel (browser) + Conversions API (server Lead on /early-access)
NEXT_PUBLIC_META_PIXEL_ID=""
# Events Manager → your Pixel → Settings → Conversions API → Generate access token (Railway: secret)
FB_CONVERSIONS_API=""
# Optional: same pixel ID server-only (otherwise NEXT_PUBLIC_META_PIXEL_ID is used)
# META_PIXEL_ID=""
# Optional: Events Manager → Test events → copy code; shows only in Test tab
# FB_CAPI_TEST_EVENT_CODE=""

# Google Analytics (public, safe to commit)
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
# Numeric Property ID from GA → Admin → Property settings (enables Realtime / Acquisition links in /admin)
NEXT_PUBLIC_GA4_PROPERTY_ID=""
# Optional label in admin GA4 panel (e.g. stream name)
NEXT_PUBLIC_GA_STREAM_LABEL=""

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Auth.js / NextAuth v5 — REQUIRED in production: non-empty AUTH_SECRET or NEXTAUTH_SECRET.
# If missing or "", /api/auth/session returns 500 ("problem with the server configuration").
# Generate: openssl rand -base64 32
AUTH_SECRET=""
# NEXTAUTH_SECRET=""
# Production: exact site origin only (https://potterymania.com) — no path; wrong path breaks auth routes.
AUTH_URL="http://localhost:3000"
# NEXTAUTH_URL=""

# Stripe (Phase 1 checkout)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Resend — orders, bookings, early-access confirmations (skipped if RESEND_API_KEY is empty)
RESEND_API_KEY=""
# Verified domain sender, e.g. PotteryMania <hello@mail.yourdomain.com> (Resend dashboard → Domains)
RESEND_FROM="PotteryMania <onboarding@resend.dev>"
# Canonical public URL; used in email footers and embedded logo. Match production https://… (also set AUTH_URL for auth)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Inbox for “new early access signup” alerts (studio + email + country). Falls back to HYPERADMIN_ALERT_EMAIL, then SEED_HYPER_ADMIN_EMAIL.
EARLY_ACCESS_NOTIFY_EMAIL=""

# Preregistration: shop, classes, and studio directory hidden from guests and customers.
# Vendors + admins may still browse. Default: ON in production, OFF in dev.
# PREREGISTRATION_ONLY=1

# Cron jobs (abandoned carts, booking reminders, finance reconcile, …)
# Use the same secret in Authorization: Bearer <CRON_SECRET> when calling /api/cron/*
CRON_SECRET=""

# OpenAI — studio AI Advisor chat (/api/studios/.../ai/chat)
OPENAI_API_KEY=""
# Optional model override (default gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
# Hyper admin account (prereg mode blocks /register — use seed once per DB, then /login)
# Railway: set both, then run once: npx prisma db seed  (or add "prisma db seed" after migrate in deploy)
SEED_HYPER_ADMIN_EMAIL=
SEED_HYPER_ADMIN_PASSWORD=

# --- Playwright E2E (tests/e2e/smoke) ---
# App must be reachable at BASE_URL with a working DATABASE_URL (same as Next dev server).
# BASE_URL=http://127.0.0.1:3000
# PLAYWRIGHT_BASE_URL=   # alias; if set, webServer is not auto-started
# TEST_EMAIL=
# TEST_PASSWORD=
# TEST_VENDOR_EMAIL=     # optional override for product-create
# TEST_VENDOR_PASSWORD=
# TEST_STUDIO_ID=        # UUID for /dashboard/products/[studioId]
# TEST_EXPERIENCE_ID=    # UUID for /classes/[experienceId] (public active experience)
# TEST_PRODUCT_ID=       # optional marketplace deep-link tests
# TEST_ADMIN_EMAIL=      # optional: early-access lead visible on /admin
# TEST_ADMIN_PASSWORD=
# STRIPE_TEST_CARD=4242424242424242

