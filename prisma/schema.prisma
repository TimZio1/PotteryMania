// PotteryMania — aligned with DATABASE_SCHEMA.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  customer
  vendor
  admin
  hyper_admin
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  passwordHash    String?   @map("password_hash")
  role            UserRole  @default(customer)
  lastLoginAt     DateTime? @map("last_login_at")
  suspendedAt     DateTime? @map("suspended_at")
  suspendedReason String?   @map("suspended_reason")
  emailVerifiedAt DateTime? @map("email_verified_at")
  /// Hyperadmin-only labels (e.g. vip, at-risk). Lowercase slug segments; not shown to the user.
  adminTags       String[]  @default([]) @map("admin_tags")
  /// Opaque token for unauthenticated iCal/WebCal feed of this user’s bookings (`/api/calendar/feed/[token]`). Treat as secret.
  calendarFeedToken String?   @unique @map("calendar_feed_token")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  ownedStudios         Studio[]              @relation("StudioOwner")
  customerProfile      CustomerProfile?
  carts                Cart[]
  orders               Order[]
  bookingsAsCustomer   Booking[]             @relation("BookingCustomer")
  bookingCancellations BookingCancellation[]
  bookingReschedules   BookingReschedule[]
  bookingAuditLogs     BookingAuditLog[]
  waitlistEntries      BookingWaitlistEntry[] @relation("WaitlistCustomer")
  reviews              Review[]
  financeLedgerEntries FinanceLedgerEntry[] @relation("LedgerUser")
  subscriptions        Subscription[]
  acquisitionAttributions AcquisitionAttribution[]
  featureUsageFacts    FeatureUsageFact[]
  discountRedemptions  DiscountRedemption[]
  priceChangeHistory   PriceChangeHistory[]
  adminAuditLogs       AdminAuditLog[]
  pricingScenarios     PricingScenario[]
  adminNotesAuthored   AdminNote[]          @relation("AdminNoteAuthor")
  adminNotesReceived   AdminNote[]          @relation("AdminNoteTarget")
  passwordResetTokens       PasswordResetToken[]
  emailVerificationTokens   EmailVerificationToken[]

  @@map("users")
}

/// One-time id consumed by Auth.js `session.update({ impersonationGrantId })` so only server-created grants can switch JWT `sub`.
model ImpersonationGrant {
  id           String   @id @default(uuid()) @db.Uuid
  adminUserId  String   @map("admin_user_id") @db.Uuid
  targetUserId String   @map("target_user_id") @db.Uuid
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([adminUserId])
  @@map("impersonation_grants")
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model CustomerProfile {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  fullName          String?  @map("full_name")
  phone             String?
  preferredLanguage String?  @map("preferred_language")
  preferredCurrency String?  @map("preferred_currency")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customer_profiles")
}

enum StudioStatus {
  draft
  pending_review
  approved
  rejected
  suspended
}

model Studio {
  id                    String       @id @default(uuid()) @db.Uuid
  ownerUserId           String       @map("owner_user_id") @db.Uuid
  displayName           String       @map("display_name")
  legalBusinessName     String       @map("legal_business_name")
  vatNumber             String       @map("vat_number")
  responsiblePersonName String       @map("responsible_person_name")
  email                 String
  phone                 String?
  country               String
  city                  String
  addressLine1          String       @map("address_line_1")
  addressLine2          String?      @map("address_line_2")
  postalCode            String?      @map("postal_code")
  latitude              Float?
  longitude             Float?
  shortDescription      String?      @map("short_description")
  longDescription       String?      @map("long_description")
  logoUrl               String?      @map("logo_url")
  coverImageUrl         String?      @map("cover_image_url")
  instagramUrl          String?      @map("instagram_url")
  facebookUrl           String?      @map("facebook_url")
  websiteUrl            String?      @map("website_url")
  preferredLanguage     String?      @map("preferred_language")
  preferredCurrency     String?      @map("preferred_currency")
  status                StudioStatus
  rejectionReason       String?      @map("rejection_reason")
  approvedAt            DateTime?    @map("approved_at")
  /// Set when the vendor pays the one-time €5 activation fee via Stripe Checkout.
  activationPaidAt      DateTime?    @map("activation_paid_at")
  activationSessionId   String?      @map("activation_session_id")
  /// Stripe Customer on the platform account (studio add-on subscriptions).
  stripePlatformCustomerId String?   @map("stripe_platform_customer_id")
  /// Hyperadmin boost for marketplace / studio directory ordering (higher = earlier).
  marketplaceRankWeight Int          @default(0) @map("marketplace_rank_weight")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  owner                User                  @relation("StudioOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  products             Product[]
  experiences          Experience[]
  cancellationPolicies CancellationPolicy[]
  bookings             Booking[]
  cartItems            CartItem[]
  orderItems           OrderItem[]
  stripeAccount        StripeAccount?
  commissionRules      CommissionRule[]
  calendarConnections  CalendarConnection[]
  vendorDomains        VendorDomain[]
  analyticsSnapshots   AnalyticsSnapshot[]
  dateBlocks           StudioDateBlock[]
  waitlistEntries      BookingWaitlistEntry[]
  reviews              Review[]
  referralInvites      ReferralInvite[]        @relation("ReferralInviter")
  referredStudios      ReferralInvite[]        @relation("ReferralAcceptedStudio")
  shippingRateQuotes   ShippingRateQuote[]
  financeLedgerEntries FinanceLedgerEntry[] @relation("LedgerStudio")
  featureUsageFacts    FeatureUsageFact[]
  kilnFirings               KilnFiring[]
  studioFeatureRequests            StudioFeatureRequest[]
  studioFeatureActivations         StudioFeatureActivation[]
  studioFeatureActivationEvents    StudioFeatureActivationEvent[]

  @@index([status])
  @@index([country, city])
  @@index([marketplaceRankWeight])
  @@map("studios")
}

model ProductCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  products Product[]

  @@map("product_categories")
}

enum ProductStockStatus {
  in_stock
  out_of_stock
  backorder
}

enum ProductStatus {
  draft
  active
  inactive
  archived
}

model Product {
  id               String             @id @default(uuid()) @db.Uuid
  studioId         String             @map("studio_id") @db.Uuid
  categoryId       String?            @map("category_id") @db.Uuid
  title            String
  slug             String
  shortDescription String?            @map("short_description")
  fullDescription  String?            @map("full_description")
  priceCents       Int                @map("price_cents")
  salePriceCents   Int?               @map("sale_price_cents")
  currency         String             @default("EUR")
  sku              String?
  stockQuantity    Int                @default(0) @map("stock_quantity")
  stockStatus      ProductStockStatus @map("stock_status")
  materials        String?
  careInstructions String?            @map("care_instructions")
  weightGrams      Int?               @map("weight_grams")
  dimensionsText   String?            @map("dimensions_text")
  shippingNotes    String?            @map("shipping_notes")
  returnNotes      String?            @map("return_notes")
  isFeatured       Boolean            @default(false) @map("is_featured")
  status           ProductStatus
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  studio     Studio           @relation(fields: [studioId], references: [id], onDelete: Cascade)
  category   ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images     ProductImage[]
  cartItems  CartItem[]
  orderItems OrderItem[]
  reviews    Review[]

  @@unique([studioId, slug])
  @@index([studioId])
  @@index([status])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  imageUrl  String   @map("image_url")
  altText   String?  @map("alt_text")
  sortOrder Int      @default(0) @map("sort_order")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

enum ExperienceType {
  one_time_event
  workshop
  masterclass
  recurring_class
  open_session
  private_session
}

enum LocationType {
  studio_address
  custom_address
  online_future
}

enum ExperienceStatus {
  draft
  active
  inactive
  archived
}

enum ExperienceVisibility {
  public
  private
}

model Experience {
  id                   String               @id @default(uuid()) @db.Uuid
  studioId             String               @map("studio_id") @db.Uuid
  title                String
  slug                 String
  shortDescription     String?              @map("short_description")
  fullDescription      String?              @map("full_description")
  experienceType       ExperienceType       @map("experience_type")
  category             String?
  skillLevel           String?              @map("skill_level")
  durationMinutes      Int                  @map("duration_minutes")
  capacity             Int
  minimumParticipants  Int                  @map("minimum_participants")
  maximumParticipants  Int                  @map("maximum_participants")
  priceCents           Int                  @map("price_cents")
  compareAtPriceCents  Int?                 @map("compare_at_price_cents")
  currency             String               @default("EUR")
  whatIsIncluded       String?              @map("what_is_included")
  whatToBring          String?              @map("what_to_bring")
  requirements         String?
  restrictions         String?
  ageRestrictionNote   String?              @map("age_restriction_note")
  accessibilityNote    String?              @map("accessibility_note")
  coverImageUrl        String?              @map("cover_image_url")
  locationType         LocationType         @map("location_type")
  venueName            String?              @map("venue_name")
  addressLine1         String?              @map("address_line_1")
  addressLine2         String?              @map("address_line_2")
  city                 String?
  country              String?
  latitude             Float?
  longitude            Float?
  cancellationPolicyId String?              @map("cancellation_policy_id") @db.Uuid
  isFeatured           Boolean              @default(false) @map("is_featured")
  /// 0 = customer pays full price at checkout; 1–10000 = deposit as basis points of the booking line (e.g. 2500 = 25%).
  bookingDepositBps    Int                  @default(0) @map("booking_deposit_bps")
  /// If true, payment succeeds but booking stays awaiting vendor approval until approved (slot is still reserved).
  bookingApprovalRequired Boolean           @default(false) @map("booking_approval_required")
  /// If true, customers can join a waitlist when the slot is full (no capacity held).
  waitlistEnabled      Boolean              @default(false) @map("waitlist_enabled")
  status               ExperienceStatus
  visibility           ExperienceVisibility @default(public)
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")

  studio               Studio              @relation(fields: [studioId], references: [id], onDelete: Cascade)
  cancellationPolicy   CancellationPolicy? @relation(fields: [cancellationPolicyId], references: [id], onDelete: SetNull)
  images               ExperienceImage[]
  recurringRules       RecurringRule[]
  bookingSlots         BookingSlot[]
  bookings             Booking[]
  cartItems            CartItem[]
  waitlistEntries      BookingWaitlistEntry[]
  reviews              Review[]

  @@unique([studioId, slug])
  @@index([studioId])
  @@index([status])
  @@map("experiences")
}

model ExperienceImage {
  id           String   @id @default(uuid()) @db.Uuid
  experienceId String   @map("experience_id") @db.Uuid
  imageUrl     String   @map("image_url")
  altText      String?  @map("alt_text")
  sortOrder    Int      @default(0) @map("sort_order")
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")

  experience Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  @@map("experience_images")
}

enum CancellationPolicyType {
  non_refundable
  refundable_until_hours
  partial_refund_until_hours
  custom
}

model CancellationPolicy {
  id               String                 @id @default(uuid()) @db.Uuid
  studioId         String?                @map("studio_id") @db.Uuid
  name             String
  policyType       CancellationPolicyType @map("policy_type")
  hoursBeforeStart Int?                   @map("hours_before_start")
  refundPercentage Int?                   @map("refund_percentage")
  customPolicyText String?                @map("custom_policy_text")
  isActive         Boolean                @default(true) @map("is_active")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")

  studio      Studio?      @relation(fields: [studioId], references: [id], onDelete: Cascade)
  experiences Experience[]

  @@map("cancellation_policies")
}

enum ScheduleType {
  one_time
  recurring_weekly
  recurring_custom_days
  manually_added_dates
  flexible_window
}

model RecurringRule {
  id                  String       @id @default(uuid()) @db.Uuid
  experienceId        String       @map("experience_id") @db.Uuid
  scheduleType        ScheduleType @map("schedule_type")
  recurrenceStartDate DateTime?    @map("recurrence_start_date") @db.Date
  recurrenceEndDate   DateTime?    @map("recurrence_end_date") @db.Date
  weekdays            String[]     @default([])
  startTime           String?      @map("start_time")
  endTime             String?      @map("end_time")
  capacityPerSlot     Int?         @map("capacity_per_slot")
  isActive            Boolean      @default(true) @map("is_active")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  experience   Experience    @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  bookingSlots BookingSlot[]

  @@map("recurring_rules")
}

enum BookingSlotStatus {
  open
  full
  blocked
  cancelled
}

model BookingSlot {
  id               String            @id @default(uuid()) @db.Uuid
  experienceId     String            @map("experience_id") @db.Uuid
  recurringRuleId  String?           @map("recurring_rule_id") @db.Uuid
  slotDate         DateTime          @map("slot_date") @db.Date
  startTime        String            @map("start_time")
  endTime          String            @map("end_time")
  capacityTotal    Int               @map("capacity_total")
  capacityReserved Int               @default(0) @map("capacity_reserved")
  seatCapacities   Json?             @map("seat_capacities")
  status           BookingSlotStatus
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  experience      Experience          @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  recurringRule   RecurringRule?      @relation(fields: [recurringRuleId], references: [id], onDelete: SetNull)
  bookings        Booking[]
  cartItems       CartItem[]
  reschedulesFrom BookingReschedule[] @relation("RescheduleFromSlot")
  reschedulesTo   BookingReschedule[] @relation("RescheduleToSlot")
  waitlistEntries BookingWaitlistEntry[]

  @@index([experienceId, slotDate])
  @@map("booking_slots")
}

enum WaitlistEntryStatus {
  active
  notified
  converted
  cancelled
}

model BookingWaitlistEntry {
  id               String                @id @default(uuid()) @db.Uuid
  studioId         String                @map("studio_id") @db.Uuid
  experienceId     String                @map("experience_id") @db.Uuid
  slotId           String                @map("slot_id") @db.Uuid
  customerUserId   String?               @map("customer_user_id") @db.Uuid
  customerName     String                @map("customer_name")
  customerEmail    String                @map("customer_email")
  participantCount Int                   @map("participant_count")
  seatType         String?               @map("seat_type")
  status           WaitlistEntryStatus   @default(active)
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  studio     Studio      @relation(fields: [studioId], references: [id], onDelete: Cascade)
  experience Experience  @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  slot       BookingSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  customerUser User?     @relation("WaitlistCustomer", fields: [customerUserId], references: [id], onDelete: SetNull)

  @@index([studioId])
  @@index([slotId])
  @@index([experienceId])
  @@map("booking_waitlist_entries")
}

enum BookingStatus {
  pending
  awaiting_vendor_approval
  confirmed
  cancellation_requested
  cancelled_by_customer
  cancelled_by_vendor
  cancelled_by_admin
  completed
  refunded
  partially_refunded
  no_show
}

enum BookingPaymentStatus {
  pending
  partial
  paid
  failed
  refunded
  partially_refunded
}

model Booking {
  id                         String               @id @default(uuid()) @db.Uuid
  studioId                   String               @map("studio_id") @db.Uuid
  experienceId               String               @map("experience_id") @db.Uuid
  slotId                     String               @map("slot_id") @db.Uuid
  customerUserId             String?              @map("customer_user_id") @db.Uuid
  customerName               String               @map("customer_name")
  customerEmail              String               @map("customer_email")
  customerPhone              String?              @map("customer_phone")
  participantCount           Int                  @map("participant_count")
  seatType                   String?              @map("seat_type")
  /// Human-readable ticket / reference (e.g. PM-A1B2C3D4), set when the booking row is created.
  ticketRef                  String?              @unique @map("ticket_ref")
  bookingStatus              BookingStatus        @map("booking_status")
  paymentStatus              BookingPaymentStatus @map("payment_status")
  /// Full booking line total (all participants × price) before any balance collection.
  totalAmountCents           Int                  @map("total_amount_cents")
  /// Amount collected in the checkout session tied to this booking (deposit or full).
  depositAmountCents         Int                  @default(0) @map("deposit_amount_cents")
  /// totalAmountCents − depositAmountCents (balance still due in person / future flow).
  remainingBalanceCents      Int                  @default(0) @map("remaining_balance_cents")
  commissionAmountCents      Int                  @default(0) @map("commission_amount_cents")
  vendorAmountCents          Int                  @default(0) @map("vendor_amount_cents")
  cancellationPolicySnapshot Json?                @map("cancellation_policy_snapshot")
  notes                      String?
  reminderScheduledAt        DateTime?             @map("reminder_scheduled_at")
  reminderSentAt             DateTime?             @map("reminder_sent_at")
  createdAt                  DateTime             @default(now()) @map("created_at")
  updatedAt                  DateTime             @updatedAt @map("updated_at")

  studio           Studio                 @relation(fields: [studioId], references: [id], onDelete: Restrict)
  experience       Experience             @relation(fields: [experienceId], references: [id], onDelete: Restrict)
  slot             BookingSlot            @relation(fields: [slotId], references: [id], onDelete: Restrict)
  customerUser     User?                  @relation("BookingCustomer", fields: [customerUserId], references: [id], onDelete: SetNull)
  cancellations    BookingCancellation[]
  reschedules      BookingReschedule[]
  orderItems       OrderItem[]
  calendarSyncLogs CalendarSyncLog[]
  auditLogs        BookingAuditLog[]
  reviews          Review[]
  financeLedgerEntries FinanceLedgerEntry[] @relation("LedgerBooking")

  @@index([studioId])
  @@map("bookings")
}

model BookingCancellation {
  id                 String   @id @default(uuid()) @db.Uuid
  bookingId          String   @map("booking_id") @db.Uuid
  cancelledByRole    String   @map("cancelled_by_role")
  cancelledByUserId  String?  @map("cancelled_by_user_id") @db.Uuid
  cancellationReason String?  @map("cancellation_reason")
  refundOutcome      String?  @map("refund_outcome")
  refundAmountCents  Int      @default(0) @map("refund_amount_cents")
  createdAt          DateTime @default(now()) @map("created_at")

  booking         Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  cancelledByUser User?   @relation(fields: [cancelledByUserId], references: [id], onDelete: SetNull)

  @@map("booking_cancellations")
}

model BookingReschedule {
  id                  String   @id @default(uuid()) @db.Uuid
  bookingId           String   @map("booking_id") @db.Uuid
  originalSlotId      String   @map("original_slot_id") @db.Uuid
  newSlotId           String   @map("new_slot_id") @db.Uuid
  rescheduledByRole   String   @map("rescheduled_by_role")
  rescheduledByUserId String?  @map("rescheduled_by_user_id") @db.Uuid
  rescheduleReason    String?  @map("reschedule_reason")
  changeFeeCents      Int      @default(0) @map("change_fee_cents")
  createdAt           DateTime @default(now()) @map("created_at")

  booking           Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  originalSlot      BookingSlot @relation("RescheduleFromSlot", fields: [originalSlotId], references: [id], onDelete: Restrict)
  newSlot           BookingSlot @relation("RescheduleToSlot", fields: [newSlotId], references: [id], onDelete: Restrict)
  rescheduledByUser User?       @relation(fields: [rescheduledByUserId], references: [id], onDelete: SetNull)

  @@map("booking_reschedules")
}

model Cart {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String?   @map("user_id") @db.Uuid
  sessionToken String?   @map("session_token")
  expiresAt    DateTime? @map("expires_at")
  lastRecoveryEmailSentAt DateTime? @map("last_recovery_email_sent_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

enum CartItemType {
  product
  booking
}

model CartItem {
  id                 String       @id @default(uuid()) @db.Uuid
  cartId             String       @map("cart_id") @db.Uuid
  itemType           CartItemType @map("item_type")
  productId          String?      @map("product_id") @db.Uuid
  experienceId       String?      @map("experience_id") @db.Uuid
  slotId             String?      @map("slot_id") @db.Uuid
  vendorId           String       @map("vendor_id") @db.Uuid
  quantity           Int          @default(1)
  participantCount   Int?         @map("participant_count")
  seatType           String?      @map("seat_type")
  priceSnapshotCents Int          @map("price_snapshot_cents")
  policySnapshot     Json?        @map("policy_snapshot")
  createdAt          DateTime     @default(now()) @map("created_at")

  cart       Cart         @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product    Product?     @relation(fields: [productId], references: [id], onDelete: Cascade)
  experience Experience?  @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  slot       BookingSlot? @relation(fields: [slotId], references: [id], onDelete: Cascade)
  vendor     Studio       @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  @@map("cart_items")
}

enum OrderStatus {
  pending
  paid
  processing
  fulfilled
  cancelled
  refunded
  partially_refunded
}

enum OrderPaymentStatus {
  pending
  paid
  failed
  refunded
  partially_refunded
}

enum FulfillmentStatus {
  pending
  processing
  shipped
  delivered
  ready_for_pickup
  cancelled
}

model Order {
  id                  String             @id @default(uuid()) @db.Uuid
  customerUserId      String?            @map("customer_user_id") @db.Uuid
  customerName        String             @map("customer_name")
  customerEmail       String             @map("customer_email")
  customerPhone       String?            @map("customer_phone")
  shippingAddressJson Json?              @map("shipping_address_json")
  billingAddressJson  Json?              @map("billing_address_json")
  notes               String?
  orderStatus         OrderStatus        @map("order_status")
  paymentStatus       OrderPaymentStatus @map("payment_status")
  fulfillmentStatus   FulfillmentStatus  @default(pending) @map("fulfillment_status")
  trackingCarrier     String?            @map("tracking_carrier")
  trackingNumber      String?            @map("tracking_number")
  trackingUrl         String?            @map("tracking_url")
  shippingMethod      String?            @map("shipping_method")
  shippingRateCents   Int                @default(0) @map("shipping_rate_cents")
  taxCents            Int                @default(0) @map("tax_cents")
  stripeCheckoutSessionId String?        @map("stripe_checkout_session_id")
  orderConfirmationSentAt DateTime?      @map("order_confirmation_sent_at")
  vendorNotificationSentAt DateTime?     @map("vendor_notification_sent_at")
  subtotalCents       Int                @default(0) @map("subtotal_cents")
  totalCents          Int                @default(0) @map("total_cents")
  currency            String             @default("EUR")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  customerUser User?       @relation(fields: [customerUserId], references: [id], onDelete: SetNull)
  items        OrderItem[]
  payments     Payment[]
  shippingRateQuotes ShippingRateQuote[]
  financeLedgerEntries FinanceLedgerEntry[] @relation("LedgerOrder")
  discountRedemptions  DiscountRedemption[]

  @@index([customerUserId])
  @@map("orders")
}

enum OrderItemType {
  product
  booking
}

model OrderItem {
  id                        String        @id @default(uuid()) @db.Uuid
  orderId                   String        @map("order_id") @db.Uuid
  itemType                  OrderItemType @map("item_type")
  productId                 String?       @map("product_id") @db.Uuid
  bookingId                 String?       @map("booking_id") @db.Uuid
  vendorId                  String        @map("vendor_id") @db.Uuid
  quantity                  Int           @default(1)
  participantCount          Int?          @map("participant_count")
  priceSnapshotCents        Int           @map("price_snapshot_cents")
  commissionSnapshotCents   Int           @default(0) @map("commission_snapshot_cents")
  vendorAmountSnapshotCents Int           @default(0) @map("vendor_amount_snapshot_cents")
  createdAt                 DateTime      @default(now()) @map("created_at")

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  vendor  Studio   @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  reviews Review[]

  @@index([vendorId])
  @@map("order_items")
}

enum PaymentRecordStatus {
