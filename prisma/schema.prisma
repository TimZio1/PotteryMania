  dedupeKey          String?                @unique @map("dedupe_key")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  @@index([status, severity])
  @@index([detectedAt])
  @@map("financial_alerts")
}

