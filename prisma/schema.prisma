// --- Financial Hyperadmin Engine ---

enum FinanceLedgerEntryType {
  gross_revenue
  discount
  refund
  stripe_fee
  tax
  platform_commission
  vendor_payout
  activation_fee
  infra_cost
  email_cost
  ai_cost
  storage_cost
  manual_adjustment
}

enum FinanceLedgerDirection {
  credit
  debit
}

model FinanceLedgerEntry {
  id           String                 @id @default(uuid()) @db.Uuid
  entryDate    DateTime               @map("entry_date") @db.Date
  entryType    FinanceLedgerEntryType @map("entry_type")
  amountCents  Int                    @map("amount_cents")
  currency     String                 @default("EUR")
  direction    FinanceLedgerDirection
  sourceSystem String                 @map("source_system")
  sourceType   String                 @map("source_type")
  sourceId     String?                @map("source_id")
  dedupeKey    String?                @unique @map("dedupe_key")
  userId       String?                @map("user_id") @db.Uuid
  studioId     String?                @map("studio_id") @db.Uuid
  orderId      String?                @map("order_id") @db.Uuid
  bookingId    String?                @map("booking_id") @db.Uuid
  subscriptionId String?              @map("subscription_id") @db.Uuid
  planId       String?                @map("plan_id") @db.Uuid
  country      String?
  featureKey   String?                @map("feature_key")
  notes        String?
  metadata     Json?                  @map("metadata")
  createdAt    DateTime               @default(now()) @map("created_at")

  user         User?         @relation("LedgerUser", fields: [userId], references: [id], onDelete: SetNull)
  studio       Studio?       @relation("LedgerStudio", fields: [studioId], references: [id], onDelete: SetNull)
  order        Order?        @relation("LedgerOrder", fields: [orderId], references: [id], onDelete: SetNull)
  booking      Booking?      @relation("LedgerBooking", fields: [bookingId], references: [id], onDelete: SetNull)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  plan         BillingPlan?  @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([entryDate])
  @@index([entryType, entryDate])
  @@index([userId, entryDate])
  @@index([studioId, entryDate])
  @@index([orderId])
  @@index([bookingId])
  @@map("finance_ledger_entries")
}

enum FinancialSnapshotScopeType {
  platform
  user
  studio
  plan
  feature
  country
  cohort
}

model FinancialSnapshotDaily {
  id           String                     @id @default(uuid()) @db.Uuid
  snapshotDate DateTime                   @map("snapshot_date") @db.Date
  scopeType    FinancialSnapshotScopeType @map("scope_type")
  /// Empty string for platform-wide scope.
  scopeId      String                     @default("") @map("scope_id")
  revenueCents Int                        @default(0) @map("revenue_cents")
  costCents    Int                        @default(0) @map("cost_cents")
  profitCents  Int                        @default(0) @map("profit_cents")
  marginBps    Int?                       @map("margin_bps")
  metrics      Json?
  createdAt    DateTime                   @default(now()) @map("created_at")
  updatedAt    DateTime                   @updatedAt @map("updated_at")

  @@unique([snapshotDate, scopeType, scopeId])
  @@index([scopeType, scopeId, snapshotDate])
  @@map("financial_snapshot_daily")
}

model FeatureUsageFact {
