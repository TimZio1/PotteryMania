  @@unique([planId, featureKey])
  @@map("plan_feature_entitlements")
}

enum SubscriptionStatus {
  active
  past_due
  canceled
  trialing
  incomplete
}

model Subscription {
  id                 String             @id @default(uuid()) @db.Uuid
  userId             String             @map("user_id") @db.Uuid
  planId             String             @map("plan_id") @db.Uuid
  status             SubscriptionStatus @default(active)
  stripeSubscriptionId String?          @unique @map("stripe_subscription_id")
  currentPeriodStart DateTime?          @map("current_period_start")
  currentPeriodEnd   DateTime?          @map("current_period_end")
  canceledAt         DateTime?          @map("canceled_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan   BillingPlan @relation(fields: [planId], references: [id], onDelete: Restrict)
  events SubscriptionEvent[]
  ledgerEntries FinanceLedgerEntry[]

  @@index([userId])
  @@index([planId])
  @@map("subscriptions")
}

enum SubscriptionEventType {
  created
  renewed
  upgraded
  downgraded
  canceled
  payment_failed
  payment_succeeded
}

model SubscriptionEvent {
  id             String                @id @default(uuid()) @db.Uuid
  subscriptionId String                @map("subscription_id") @db.Uuid
  eventType      SubscriptionEventType @map("event_type")
  payload        Json?
  createdAt      DateTime              @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, createdAt])
  @@map("subscription_events")
}

model Coupon {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  name        String?
  percentOff  Int?     @map("percent_off")
  amountOffCents Int?  @map("amount_off_cents")
  currency    String?  @default("EUR")
  maxRedemptions Int? @map("max_redemptions")
  redeemedCount Int    @default(0) @map("redeemed_count")
  validFrom   DateTime? @map("valid_from")
  validUntil  DateTime? @map("valid_until")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  redemptions DiscountRedemption[]

  @@map("coupons")
}

model DiscountRedemption {
  id        String   @id @default(uuid()) @db.Uuid
  couponId  String   @map("coupon_id") @db.Uuid
  orderId   String?  @map("order_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  amountCents Int    @map("amount_cents")
  createdAt DateTime @default(now()) @map("created_at")

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  order  Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([couponId])
  @@map("discount_redemptions")
}

enum PriceChangeEntityType {
  product
  experience
  billing_plan
}

model PriceChangeHistory {
  id         String                @id @default(uuid()) @db.Uuid
  entityType PriceChangeEntityType @map("entity_type")
  entityId   String                @map("entity_id") @db.Uuid
  oldPriceCents Int?               @map("old_price_cents")
  newPriceCents Int                @map("new_price_cents")
  currency   String                @default("EUR")
  changedById String?             @map("changed_by_id") @db.Uuid
  reason     String?
  createdAt  DateTime              @default(now()) @map("created_at")

  changedBy User? @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@map("price_change_history")
}

model AdminAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  beforeJson  Json?    @map("before_json")
  afterJson   Json?    @map("after_json")
  reason      String?
  createdAt   DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, createdAt])
  @@map("admin_audit_logs")
}

model AdminNote {
  id           String   @id @default(uuid()) @db.Uuid
  authorUserId String?  @map("author_user_id") @db.Uuid
  targetUserId String   @map("target_user_id") @db.Uuid
  content      String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  author User? @relation("AdminNoteAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  target User  @relation("AdminNoteTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([targetUserId, createdAt])
  @@map("admin_notes")
}

model AcquisitionAttribution {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  utmSource    String?  @map("utm_source")
  utmMedium    String?  @map("utm_medium")
  utmCampaign  String?  @map("utm_campaign")
  referrer     String?
  landingPath  String?  @map("landing_path")
  firstSeenAt  DateTime @default(now()) @map("first_seen_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("acquisition_attributions")
}

enum KilnFiringStatus {
  draft
  loading
  firing
  cooling
  complete
}

model KilnFiring {
  id          String           @id @default(uuid()) @db.Uuid
  studioId    String           @map("studio_id") @db.Uuid
  label       String?
  scheduledAt DateTime?        @map("scheduled_at")
  status      KilnFiringStatus @default(draft)
  notes       String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  studio Studio    @relation(fields: [studioId], references: [id], onDelete: Cascade)
  items  KilnItem[]

  @@index([studioId, createdAt])
  @@map("kiln_firings")
}

model KilnItem {
  id          String   @id @default(uuid()) @db.Uuid
  firingId    String   @map("firing_id") @db.Uuid
  description String
  status      String   @default("queued")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  firing KilnFiring @relation(fields: [firingId], references: [id], onDelete: Cascade)

  @@index([firingId])
  @@map("kiln_items")
}

/// Studio owner intent for add-on features (billing integration can map later).
model StudioFeatureRequest {
  id         String   @id @default(uuid()) @db.Uuid
  studioId   String   @map("studio_id") @db.Uuid
  featureKey String   @map("feature_key")
  desiredOn  Boolean  @default(false) @map("desired_on")
  updatedAt  DateTime @updatedAt @map("updated_at")
  createdAt  DateTime @default(now()) @map("created_at")

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@unique([studioId, featureKey])
  @@index([studioId])
  @@map("studio_feature_requests")
}

enum PlatformFeatureVisibility {
  public
  hidden
  beta
}

enum StudioFeatureActivationStatus {
  inactive
  active
  trialing
  pending_cancel
}

/// Append-only audit trail for add-on activation changes (analytics + support).
enum StudioFeatureActivationEventKind {
  vendor_enable
  vendor_disable
  admin_active
  admin_inactive
  admin_override_price
  checkout_single
  checkout_bundle
  stripe_subscription_ended
}

/// Global add-on catalog (Hyperadmin-managed). Slugs match legacy `feature_key` values.
model PlatformFeature {
  id             String                    @id @default(uuid()) @db.Uuid
  slug           String                    @unique
  name           String
  description    String                    @default("")
  category       String                    @default("addons")
  priceCents     Int                       @map("price_cents")
  currency       String                    @default("EUR")
  isActive       Boolean                   @default(true) @map("is_active")
  visibility     PlatformFeatureVisibility @default(public)
  /// When true, every studio has access unless Hyperadmin turns this off for monetization.
  grantByDefault Boolean                   @default(true) @map("grant_by_default")
  /// Recurring Stripe Price id (`price_...`) when add-ons are sold via Billing.
  stripePriceId  String?                  @map("stripe_price_id")
  sortOrder      Int                       @default(0) @map("sort_order")
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")

  activations        StudioFeatureActivation[]
  bundleItems        FeatureBundleItem[]
  activationEvents   StudioFeatureActivationEvent[]

  @@index([isActive])
  @@map("platform_features")
}

model StudioFeatureActivationEvent {
  id                   String                           @id @default(uuid()) @db.Uuid
  studioId             String                           @map("studio_id") @db.Uuid
  featureId            String                           @map("feature_id") @db.Uuid
  kind                 StudioFeatureActivationEventKind
  stripeSubscriptionId String?                          @map("stripe_subscription_id")
  payloadJson          Json?                            @map("payload_json")
  createdAt            DateTime                         @default(now()) @map("created_at")

  studio  Studio          @relation(fields: [studioId], references: [id], onDelete: Cascade)
  feature PlatformFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@index([featureId, createdAt])
  @@index([createdAt])
  @@map("studio_feature_activation_events")
}

model StudioFeatureActivation {
  id                         String                        @id @default(uuid()) @db.Uuid
  studioId                   String                        @map("studio_id") @db.Uuid
  featureId                  String                        @map("feature_id") @db.Uuid
  status                     StudioFeatureActivationStatus @default(inactive)
  trialEndsAt                DateTime?                     @map("trial_ends_at")
  deactivatesAt              DateTime?                     @map("deactivates_at")
  /// Stripe Subscription id for this add-on when billed separately (one sub per feature).
  stripeSubscriptionId       String?                       @map("stripe_subscription_id")
  stripeSubscriptionItemId   String?                       @map("stripe_subscription_item_id")
  overridePriceCents         Int?                          @map("override_price_cents")
  activatedAt                DateTime?                     @map("activated_at")
  createdAt                  DateTime                      @default(now()) @map("created_at")
  updatedAt                  DateTime                      @updatedAt @map("updated_at")

  studio  Studio          @relation(fields: [studioId], references: [id], onDelete: Cascade)
  feature PlatformFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([studioId, featureId])
  @@index([studioId])
  @@index([featureId])
  @@index([stripeSubscriptionId])
  @@map("studio_feature_activations")
}

/// Hyperadmin-defined bundle of catalog features (discounted package price vs à la carte).
model FeatureBundle {
  id          String    @id @default(uuid()) @db.Uuid
  slug        String    @unique
  name        String
  description String    @default("")
  priceCents  Int       @map("price_cents")
  currency    String    @default("EUR")
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  validFrom   DateTime? @map("valid_from")
  validUntil  DateTime? @map("valid_until")
  /// Optional single recurring Stripe Price for the whole bundle (platform Billing).
  stripePriceId String?   @map("stripe_price_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  items FeatureBundleItem[]

  @@index([isActive])
  @@map("feature_bundles")
}

model FeatureBundleItem {
  id        String @id @default(uuid()) @db.Uuid
  bundleId  String @map("bundle_id") @db.Uuid
  featureId String @map("feature_id") @db.Uuid
  sortOrder Int    @default(0) @map("sort_order")

  bundle  FeatureBundle   @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  feature PlatformFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([bundleId, featureId])
  @@index([bundleId])
  @@index([featureId])
  @@map("feature_bundle_items")
}
